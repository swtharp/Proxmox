#!/bin/sh
# Code to backup PVE host then send to BackBlaze via b2 command.
# Stored on PVE host in /var/tmp and BackBlaze in my-proxmox-pve both for 7 days
BACKUP_PATH="/var/backup/"
BACKUP_FILE="pve-host"
KEEP_DAYS=7
PVE_BACKUP_SET="/etc/pve/ /etc/lvm/ /etc/modprobe.d/ /etc/network/interfaces /etc/vzdump.conf /etc/sysctl.conf /etc/resolv.conf /etc/ksmtuned.conf /etc/hosts /etc/hostname /etc/cron* /etc/a>
#PVE_CUSTOM_BACKUP_SET=""
tar -czf $BACKUP_PATH$BACKUP_FILE-$(date +%Y_%m_%d-%H_%M_%S).tar.gz --absolute-names $PVE_BACKUP_SET $PVE_CUSTOM_BACKUP_SET
#b2 file upload --quiet  my-proxmox-pve $BACKUP_PATH$BACKUP_FILE-$(date +%Y_%m_%d-%H_%M_%S).tar.gz $BACKUP_FILE-$(date +%Y_%m_%d-%H_%M_%S).tar.gz  > /dev/null
# rclone copy $BACKUP_PATH$BACKUP_FILE-$(date +%Y_%m_%d-%H_%M_%S).tar.gz  b2:my-proxmox-pve > /dev/null
find $BACKUP_PATH$BACKUP_FILE-* -mindepth 0 -maxdepth 0 -depth -mtime +$KEEP_DAYS -delete
rclone sync /var/backup b2:my-proxmox-pve
~                                                                                                  
